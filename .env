
# ==========================================
# 🔐 ENTERPRISE LAKEHOUSE SECURITY & CONFIG
# ==========================================

# --- 🐘 POSTGRESQL (OPERASYONEL DB) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=market_db
POSTGRES_USER=admin_lakehouse
POSTGRES_PASSWORD=sifre olusturun

# --- 🗄️ MINIO (S3 DATA LAKE) ---
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=sifre olusturun

# --- ☁️ AWS S3 UYUMLULUĞU (Spark, Delta & MLflow İçin) ---
# (MinIO şifreleriyle aynı olmalı çünkü Spark AWS SDK kullanarak MinIO'ya bağlanıyor)
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=sifre olusturun
AWS_REGION=us-east-1
S3_BUCKET_NAME=market-data

# --- 🚀 KAFKA & STREAMING ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_MARKET=market_data

# --- 🧪 MLOps (MLFLOW) ---
MLFLOW_TRACKING_URI=http://mlflow:5000

# --- 📈 İZLEME VE ANALİTİK (GRAFANA & METABASE) ---
GF_SECURITY_ADMIN_USER=grafana_admin
GF_SECURITY_ADMIN_PASSWORD=SuperSecret_Grafana_2026

# --- 📈Yapay Zeka(Gemini) ---
GEMINI_API_KEY=


